# Supabase — Project Settings > API
SUPABASE_URL=
# Not yet used by any Phase 2 code (everything runs server-side via the
# service_role key below); kept here for future client-side use.
SUPABASE_ANON_KEY=
# Server-only. Bypasses Row Level Security — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Embeddings — lib/ai/embeddings.ts picks the provider at runtime from
# EMBEDDING_PROVIDER alone; no other code needs to change to switch.
# Supported values: "huggingface" (default), "openai"
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
# huggingface default: sentence-transformers/all-MiniLM-L6-v2 (384 dimensions,
#   matches document_chunks.embedding in supabase/migrations/0001_init.sql)
# openai default: text-embedding-3-small (1536 dimensions — switching to this
#   requires a migration that alters the embedding column's width)
EMBEDDING_MODEL=

# LLM — lib/ai/llm.ts picks the provider at runtime from LLM_PROVIDER
# alone, same swappable-via-env-vars pattern as embeddings above.
# Supported values: "groq" (default), "openai"
LLM_PROVIDER=
LLM_API_KEY=
# groq default: openai/gpt-oss-120b (Groq's own recommended general-purpose
#   model; llama-3.3-70b-versatile/llama-3.1-8b-instant are deprecated as of
#   2026-08-16, so this build intentionally doesn't default to either)
# openai default: gpt-4o-mini
LLM_MODEL=

# Vapi — real voice call (Phase 3). All three are required together for the
# voice overlay to run a real call; if any is missing, GET /api/config/status
# reports demoMode:true and the overlay falls back to the Phase 1 canned demo.
# VAPI_PUBLIC_KEY is safe to expose to the browser (it's the direct
#   equivalent of a Stripe publishable key — see @vapi-ai/web's own
#   quickstart) and is served to the client via /api/config/status.
VAPI_PUBLIC_KEY=
# Server-only. Only used by scripts/create-vapi-assistant.mjs (optional
#   assistant provisioning via Vapi's REST API) — no request-serving route
#   reads this.
VAPI_PRIVATE_KEY=
# Create/update the assistant with: node scripts/create-vapi-assistant.mjs
#   https://your-public-app-url — or create it by hand in the Vapi
#   dashboard with model.provider="custom-llm" and model.url pointed at
#   {your app's origin}/api/vapi (see Project_status.md for the full JSON).
VAPI_ASSISTANT_ID=
