SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Same project URL and anon key as above, re-exposed under NEXT_PUBLIC_ so the
# browser can read them. Required for large-file uploads: the browser PUTs the
# file directly to Supabase Storage via a signed upload URL (bypassing our own
# API routes, since Vercel serverless functions cap request bodies at ~4.5MB),
# and that direct request needs a valid apikey header to reach Supabase at all.
# The anon key is meant to be public — it has no access beyond what a signed
# URL's own token already grants for that one upload. Never put
# SUPABASE_SERVICE_ROLE_KEY here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supported values: "huggingface" (default), "openai"
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
# The embedding model to use for the provider above.
#   huggingface default: sentence-transformers/all-MiniLM-L6-v2 (384 dimensions)
#   openai default:      text-embedding-3-small (1536 dimensions)
#
# IMPORTANT — dimension changes require a database migration:
# document_chunks.embedding is a fixed-width pgvector column (currently
# vector(384); see supabase/migrations/0001_init.sql). If you switch
# EMBEDDING_MODEL to one with a DIFFERENT output dimension than the current
# column width, the app will start failing to store/query embeddings until
# you resize the column and its index. Run this in Supabase's SQL editor
# (replace 1536 with your new model's actual output dimension):
#
#   drop index if exists document_chunks_embedding_hnsw_idx;
#   alter table document_chunks alter column embedding type vector(1536);
#   create index document_chunks_embedding_hnsw_idx
#     on document_chunks using hnsw (embedding vector_cosine_ops);
#
# This does NOT re-embed existing rows — their old-dimension vectors are
# incompatible with the new column type. After running the SQL above,
# re-upload (or otherwise reprocess) every existing document so its chunks
# get regenerated at the new dimension. Embeddings from different dimensions
# are never compatible with each other, even if you switch back later.
EMBEDDING_MODEL=

# LLM — lib/ai/llm.ts picks the provider at runtime from LLM_PROVIDER alone,
# the same swappable-via-env-vars pattern as embeddings above.
# Supported values: "groq" (default), "openai"
LLM_PROVIDER=
LLM_API_KEY=
# The chat/completion model to use for the provider above.
#   groq default:   openai/gpt-oss-120b
#   openai default: gpt-4o-mini
LLM_MODEL=

VAPI_PUBLIC_KEY=
VAPI_PRIVATE_KEY=
VAPI_ASSISTANT_ID=
